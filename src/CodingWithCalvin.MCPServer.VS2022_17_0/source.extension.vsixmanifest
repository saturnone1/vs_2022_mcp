<?xml version="1.0" encoding="utf-8"?>
<PackageManifest Version="2.0.0" xmlns="http://schemas.microsoft.com/developer/vsx-schema/2011" xmlns:d="http://schemas.microsoft.com/developer/vsx-schema-design/2011">
    <Metadata>
        <Identity Id="VS-MCPServer" Version="1.0.2" Language="en-US" Publisher="Coding With Calvin" />
        <DisplayName>MCP Server</DisplayName>
        <Description xml:space="preserve">Exposes Visual Studio features as an MCP (Model Context Protocol) server, enabling AI assistants like Claude to interact with Visual Studio programmatically.</Description>
        <MoreInfo>https://github.com/CodingWithCalvin/VS-MCPServer</MoreInfo>
        <License>resources\LICENSE.txt</License>
        <Icon>resources\logo.png</Icon>
        <PreviewImage>resources\logo.png</PreviewImage>
        <Tags>MCP, AI, Claude, LLM, Automation</Tags>
    </Metadata>
    <Installation>
        <InstallationTarget Id="Microsoft.VisualStudio.Community" Version="[17.0,17.12)">
            <ProductArchitecture>amd64</ProductArchitecture>
        </InstallationTarget>
        <InstallationTarget Id="Microsoft.VisualStudio.Pro" Version="[17.0,17.12)">
            <ProductArchitecture>amd64</ProductArchitecture>
        </InstallationTarget>
        <InstallationTarget Id="Microsoft.VisualStudio.Enterprise" Version="[17.0,17.12)">
            <ProductArchitecture>amd64</ProductArchitecture>
        </InstallationTarget>
    </Installation>
    <Dependencies>
        <Dependency Id="Microsoft.Framework.NDP" DisplayName="Microsoft .NET Framework" d:Source="Manual" Version="[4.8,)" />
    </Dependencies>
    <Prerequisites>
        <Prerequisite Id="Microsoft.VisualStudio.Component.CoreEditor" Version="[17.0,)" DisplayName="Visual Studio core editor" />
    </Prerequisites>
    <Assets>
        <Asset Type="Microsoft.VisualStudio.VsPackage" Path="CodingWithCalvin.MCPServer.pkgdef" />
        <Asset Type="Microsoft.VisualStudio.MefComponent" Path="CodingWithCalvin.MCPServer.dll" />
    </Assets>
</PackageManifest>
